<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suppressions PUBLIC
        "-//Checkstyle//DTD SuppressionFilter Configuration 1.2//EN"
        "https://checkstyle.org/dtds/suppressions_1_2.dtd">

<suppressions>

    <!-- Suppress all checks on Protobuf-generated sources -->
    <suppress
            files="[/\\]generated-sources[/\\]"
            checks=".*"/>

    <!-- Suppress Javadoc on test classes and methods -->
    <suppress
            files="[/\\]src[/\\]test[/\\]"
            checks="JavadocMethod|JavadocType|MissingJavadocMethod"/>

    <!-- Allow longer lines in example modules -->
    <suppress
            files="[/\\]examples[/\\]"
            checks="LineLength"/>

</suppressions>